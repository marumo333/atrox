{
  "name": "atrox",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @atrox/db drizzle-kit generate",
    "db:migrate": "pnpm --filter @atrox/db drizzle-kit migrate",
    "db:studio": "pnpm --filter @atrox/db drizzle-kit studio"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
